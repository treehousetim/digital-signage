{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/treehousetim/digital-signage/schema.json",
  "title": "Digital Signage Menu Definition",
  "description": "Design system for full-screen menu displays. Most fields are optional — defaults handle the rest.",
  "type": "object",
  "required": ["areas"],
  "properties": {
    "uses": {
      "description": "External JSON file(s) to import as defaults. String for one file, array for multiple (layered in order, later wins). User inline values override all imports.",
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "vars": {
      "type": "object",
      "description": "Design vars (named values). Reference any value with $name in spatial, color, or font size fields.",
      "properties": {
        "palette": {
          "type": "object",
          "description": "Named colors. Built-in keys: background, surface, text, muted, accent, divider. Add your own freely.",
          "additionalProperties": { "type": "string" }
        },
        "spacing": {
          "type": "object",
          "description": "Named spacing values (percentage of viewport). Built-in keys: none, xs, sm, md, lg, xl, xxl.",
          "additionalProperties": { "type": "number" }
        },
        "type_scale": {
          "type": "object",
          "description": "Named font sizes (em multipliers). Built-in keys: xs, sm, base, md, lg, xl, hero.",
          "additionalProperties": { "type": "number" }
        }
      }
    },
    "theme": { "$ref": "#/$defs/theme" },
    "header": {
      "type": "object",
      "description": "Header content. Visual properties live in theme.header.",
      "properties": {
        "elements": {
          "type": "array",
          "items": { "$ref": "#/$defs/header_element" }
        }
      }
    },
    "areas": {
      "type": "array",
      "items": { "$ref": "#/$defs/area" }
    }
  },
  "$defs": {
    "divider_config": {
      "type": "object",
      "properties": {
        "color":  { "type": "string", "description": "CSS color or '$name' palette reference." },
        "width":  { "type": "number", "default": 1 },
        "style":  { "type": "string", "enum": ["solid", "dashed", "dotted"], "default": "solid" },
        "sides":   {
          "type": "array",
          "description": "Divider orientation: 'tb' draws top+bottom borders, 'lr' draws left+right borders. For standalone divider elements (items, variations) 'tb' is a horizontal line and 'lr' is a vertical line.",
          "items": { "type": "string", "enum": ["tb", "lr"] }
        },
        "padding": { "$ref": "#/$defs/spacing_value", "description": "Padding applied on each active side (between content and divider line)." },
      }
    },
    "spacing_value": {
      "description": "A length value. Strings: '12' or '12px' (pixels), '1.5em', '0.5rem', '10pt', etc. (any CSS unit passed through), '5%' (percent of viewport), '$name' (var reference). Bare numbers are pixels.",
      "oneOf": [
        { "type": "number" },
        { "type": "string" }
      ]
    },
    "padding": {
      "description": "Padding shorthand. A number/var applies uniformly. An object sets each side independently.",
      "oneOf": [
        { "$ref": "#/$defs/spacing_value" },
        {
          "type": "object",
          "properties": {
            "top":    { "$ref": "#/$defs/spacing_value" },
            "right":  { "$ref": "#/$defs/spacing_value" },
            "bottom": { "$ref": "#/$defs/spacing_value" },
            "left":   { "$ref": "#/$defs/spacing_value" }
          }
        }
      ]
    },
    "font": {
      "description": "Font definition. Can be an object or a string reference to a theme.fonts role.",
      "oneOf": [
        {
          "type": "string",
          "description": "Reference to a theme font role. Built-in roles: header, area_title, item_name, price, description. Custom roles can be added by defining additional keys in theme.fonts."
        },
        {
          "type": "object",
          "properties": {
            "extends": { "type": "string", "description": "Inherit from a theme font role and override specific fields." },
            "family": { "type": "string", "description": "Font family. Google Fonts auto-loaded." },
            "weight": { "type": "string" },
            "color":  { "type": "string", "description": "CSS color or '$name' palette reference." },
            "size":   { "description": "em number or '$name' type_scale reference." }
          }
        }
      ]
    },
    "theme": {
      "type": "object",
      "description": "Visual contract: layout, colors, fonts, dividers, and per-element defaults. Every group has sensible defaults and can be partially overridden.",
      "properties": {
        "layout": {
          "type": "object",
          "description": "Canvas dimensions and content arrangement.",
          "properties": {
            "resolution": { "type": "string", "enum": ["1080", "2k", "4k"], "default": "4k" },
            "orientation": { "type": "string", "enum": ["landscape", "portrait"], "default": "landscape" },
            "mode": { "type": "string", "enum": ["display", "preview"], "default": "display" },
            "viewport_padding": { "$ref": "#/$defs/padding" },
            "row_gutter": { "$ref": "#/$defs/spacing_value" },
            "columns": { "type": "integer", "minimum": 1, "maximum": 6, "default": 1 },
            "column_gutter": { "$ref": "#/$defs/spacing_value" }
          }
        },
        "colors": {
          "type": "object",
          "description": "Semantic color slots. Each defaults to a $palette reference.",
          "properties": {
            "background": { "type": "string" },
            "surface":    { "type": "string" },
            "text":       { "type": "string" },
            "muted":      { "type": "string" },
            "accent":     { "type": "string" },
            "divider":    { "type": "string" }
          }
        },
        "fonts": {
          "type": "object",
          "description": "Named font roles referenced from elements. Built-in roles: header, area_title, item_name, price, description. Add any number of custom roles.",
          "additionalProperties": { "$ref": "#/$defs/font" }
        },
        "dividers": {
          "type": "object",
          "description": "Divider lines for header, areas, items, and variations. Each type inherits from 'default'.",
          "properties": {
            "default":   { "$ref": "#/$defs/divider_config" },
            "header":    { "$ref": "#/$defs/divider_config" },
            "area":      { "$ref": "#/$defs/divider_config" },
            "item":      { "$ref": "#/$defs/divider_config" },
            "variation": { "$ref": "#/$defs/divider_config" }
          }
        },
        "areas": {
          "type": "object",
          "description": "Default settings inherited by all areas.",
          "properties": {
            "padding":      { "$ref": "#/$defs/padding" },
            "background":   { "type": "string" },
            "border": {
              "type": "object",
              "properties": {
                "color":  { "type": "string" },
                "width":  { "type": "number", "default": 1 },
                "style":  { "type": "string", "enum": ["solid", "dashed", "dotted"], "default": "solid" },
                "radius": { "type": "number" }
              }
            },
            "title_font":   { "$ref": "#/$defs/font" },
            "column_count": { "type": "integer", "default": 1 },
            "gutter":       { "$ref": "#/$defs/spacing_value" },
            "item_align":   { "type": "string", "enum": ["left", "center", "right"], "default": "left" },
            "price_align":  { "type": "string", "enum": ["left", "right"], "default": "right" }
          }
        },
        "items": {
          "type": "object",
          "description": "Default settings inherited by all items.",
          "properties": {
            "padding":          { "$ref": "#/$defs/padding" },
            "name_font":        { "$ref": "#/$defs/font" },
            "price_font":       { "$ref": "#/$defs/font" },
            "description_font": { "$ref": "#/$defs/font" },
            "variation_font":   { "$ref": "#/$defs/font" },
            "align":            { "type": "string", "enum": ["left", "center", "right"], "default": "left" },
            "price_line": {
              "type": "object",
              "description": "Optional leader between item name and price.",
              "properties": {
                "style":         { "type": "string", "enum": ["none", "dots", "dashes", "solid"], "default": "none" },
                "color":         { "type": "string" },
                "thickness":     { "type": "number", "default": 1 },
                "segment_size":  { "type": "number", "description": "Dot diameter or dash length (px)." },
                "gap_size":      { "type": "number", "description": "Space between dots/dashes (px)." },
                "padding_left":  { "$ref": "#/$defs/spacing_value" },
                "padding_right": { "$ref": "#/$defs/spacing_value" }
              }
            }
          }
        },
        "pricing": {
          "type": "object",
          "properties": {
            "symbol": { "type": "string", "default": "", "description": "Currency symbol." },
            "symbol_position": { "type": "string", "enum": ["before", "after"], "default": "before" },
            "symbol_space": { "type": "boolean", "default": false, "description": "Insert a space between the symbol and the number." },
            "format": { "type": "string", "enum": ["full", "fewest"], "default": "full" }
          }
        },
        "header": {
          "type": "object",
          "description": "Visual properties of the header region (content lives in top-level header.elements).",
          "properties": {
            "height":     { "$ref": "#/$defs/spacing_value" },
            "padding":    { "$ref": "#/$defs/padding" },
            "background": { "type": "string" },
            "columns": {
              "type": "object",
              "description": "Per-column sizing. Empty columns auto-collapse.",
              "properties": {
                "left":   { "type": "object", "properties": { "mode": { "type": "string", "enum": ["fit", "fill"] } } },
                "center": { "type": "object", "properties": { "mode": { "type": "string", "enum": ["fit", "fill"] } } },
                "right":  { "type": "object", "properties": { "mode": { "type": "string", "enum": ["fit", "fill"] } } }
              }
            }
          }
        }
      }
    },
    "header_element": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "id":       { "type": "string", "description": "Auto-generated if omitted." },
            "type":     { "const": "text" },
            "text":     { "type": "string" },
            "font":     { "$ref": "#/$defs/font" },
            "position": { "type": "string", "enum": ["left", "center", "right"], "default": "center" }
          }
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "id":         { "type": "string" },
            "type":       { "const": "logo" },
            "src":        { "type": "string" },
            "max_height": { "$ref": "#/$defs/spacing_value", "default": 4 },
            "position":   { "type": "string", "enum": ["left", "center", "right"], "default": "left" }
          }
        }
      ]
    },
    "area": {
      "type": "object",
      "description": "A leaf area (with items) or a group area (with nested areas). Most fields inherit from theme.areas.",
      "properties": {
        "id":           { "type": "string", "description": "Auto-generated from title if omitted." },
        "title":        { "type": "string" },
        "icon":         { "type": "string", "description": "URL to an image or SVG rendered above the title." },
        "icon_height":  { "$ref": "#/$defs/spacing_value", "description": "Max height of the icon. Defaults to 25% of viewport height." },
        "subtitle":     { "type": "string", "description": "Secondary text below the title, styled with the description font role." },
        "background":   { "type": "string", "description": "CSS color or linear-gradient(...) string. Overrides theme.areas.background." },
        "padding":      { "$ref": "#/$defs/padding" },
        "title_font":   { "$ref": "#/$defs/font" },
        "column_count": { "type": "integer" },
        "columns":      { "type": "integer", "description": "For group areas: number of sub-area columns." },
        "gutter":       { "$ref": "#/$defs/spacing_value" },
        "align":        { "type": "string", "enum": ["left", "center", "right"] },
        "valign":       { "type": "string", "enum": ["top", "center", "bottom"] },
        "item_align":   { "type": "string", "enum": ["left", "center", "right"] },
        "price_align":  { "type": "string", "enum": ["left", "right"] },
        "style": {
          "type": "object",
          "description": "Per-area visual overrides.",
          "properties": {
            "title_font": { "$ref": "#/$defs/font" },
            "background": { "type": "string" }
          }
        },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/item" }
        },
        "areas": {
          "type": "array",
          "description": "Nested sub-areas. Mutually exclusive with items.",
          "items": { "$ref": "#/$defs/area" }
        }
      }
    },
    "item": {
      "type": "object",
      "description": "Menu item. Only `name` is required.",
      "required": ["name"],
      "properties": {
        "id":          { "type": "string", "description": "Auto-generated from name if omitted." },
        "name":        { "type": "string" },
        "description": { "type": "string" },
        "price":       { "type": "string", "description": "Display string. Numeric values are formatted per theme.pricing." },
        "variations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "id":    { "type": "string" },
              "name":  { "type": "string" },
              "price": { "type": "string" }
            }
          }
        },
        "padding": { "$ref": "#/$defs/padding" },
        "align":   { "type": "string", "enum": ["left", "center", "right"] },
        "hide_if_empty":         { "type": "boolean", "default": false },
        "variations_inline":     { "type": "boolean", "default": true },
        "show_variation_prices": { "type": "boolean", "default": true },
        "style": {
          "type": "object",
          "description": "Per-item visual overrides.",
          "properties": {
            "name_font":  { "$ref": "#/$defs/font" },
            "price_font": { "$ref": "#/$defs/font" }
          }
        }
      }
    }
  }
}
